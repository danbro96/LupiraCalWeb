# Image tag to run (pin to the commit sha for rollback; default: latest).
IMAGE_TAG=latest

# Host port (4088x block (the API is :40880); behind the tunnel at cal.lupira.com).
CAL_WEB_PORT=40881

# Authentik OIDC — the BFF reuses the EXISTING `lupira-cal` client (the one lupira-cal-api validates:
# same issuer, aud=lupira-cal), so the forwarded token is accepted by the API as-is.
# Add this web's redirect URI (https://cal.lupira.com/signin-oidc) to that client in Authentik.
AUTH_AUTHORITY=https://auth.lupira.com/application/o/lupira-cal/
AUTH_CLIENT_ID=lupira-cal
# Set only if the lupira-cal client is Confidential in Authentik; leave blank for Public+PKCE.
AUTH_CLIENT_SECRET=

# Audience scopes the BFF requests so Authentik stamps the aud each upstream validates. Each needs the
# matching scope mapping assigned to the lupira-cal provider AND selected in its Scopes list.
AUTH_SCOPE_CONTACT=lupira-contact-aud
AUTH_SCOPE_GEO=lupira-geo-aud

# Upstreams the BFF proxies to (the signed-in user's forwarded token authenticates each). Public
# defaults shown; on a shared Docker network, point these at the container-internal address instead
# — e.g. CAL_API_BASE_URL=http://lupira-cal-api:8080 — to skip the public round-trip.
# geo-api/contact-api validate an audience; the BFF supplies it via AUTH_SCOPE_GEO/AUTH_SCOPE_CONTACT above.
CAL_API_BASE_URL=https://cal-api.lupira.com
GEO_API_BASE_URL=https://geo-api.lupira.com
CONTACT_API_BASE_URL=https://contact-api.lupira.com

# OpenTelemetry → OpenObserve collector (blank endpoint = export disabled). HEADERS carries the
# OpenObserve Basic auth (Authorization=Basic <base64>). Protocol/interval/attrs have compose defaults.
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_METRIC_EXPORT_INTERVAL=300000
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=prod,service.name=lupira-cal-web
