{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Duende": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Oidc": {
      "Authority": "https://auth.lupira.com/application/o/lupira-cal/",
      "ClientId": "lupira-cal",
      "ClientSecret": "",
      "Scopes": [ "openid", "profile", "email", "groups", "offline_access", "lupira-contact-aud", "lupira-geo-aud" ]
    }
  },
  "DataProtection": {
    "KeyPath": "/keys"
  },
  "ReverseProxy": {
    "Routes": {
      "cal-member": {
        "ClusterId": "cal-api",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      },
      "geo-member": {
        "ClusterId": "geo-api",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/geo-api/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/geo-api" } ]
      },
      "contact-member": {
        "ClusterId": "contact-api",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/contact-api/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/contact-api" } ]
      }
    },
    "Clusters": {
      "cal-api": {
        "Destinations": {
          "primary": { "Address": "https://cal-api.lupira.com" }
        }
      },
      "geo-api": {
        "Destinations": {
          "primary": { "Address": "https://geo-api.lupira.com" }
        }
      },
      "contact-api": {
        "Destinations": {
          "primary": { "Address": "https://contact-api.lupira.com" }
        }
      }
    }
  }
}
