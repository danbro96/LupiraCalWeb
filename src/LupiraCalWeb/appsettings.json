{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Duende": "Warning",
      "Yarp": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Oidc": {
      "Authority": "https://auth.lupira.com/application/o/lupira-cal/",
      "ClientId": "lupira-cal",
      "ClientSecret": "",
      "Scopes": [ "openid", "profile", "email", "groups", "offline_access" ]
    }
  },
  "DataProtection": {
    "KeyPath": "/keys"
  },
  "ReverseProxy": {
    "Routes": {
      "cal-member": {
        "ClusterId": "cal-api",
        "AuthorizationPolicy": "Default",
        "Match": { "Path": "/api/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api" } ]
      }
    },
    "Clusters": {
      "cal-api": {
        "Destinations": {
          "primary": { "Address": "https://cal-api.lupira.com" }
        }
      }
    }
  }
}
