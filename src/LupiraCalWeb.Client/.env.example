# The member API and auth are same-origin via the BFF — the SPA calls /api and /auth directly, so
# there is normally nothing to set here.

# Override the API path prefix only if the BFF mounts the proxy somewhere other than /api.
# VITE_API_BASE_URL=/api

# Local dev: the Vite dev server proxies /api, /auth, … to the BFF. Override its origin if not :5181.
# BACKEND_ORIGIN=http://localhost:5181
