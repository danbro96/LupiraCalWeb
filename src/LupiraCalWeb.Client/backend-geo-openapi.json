    "/geocode/reverse": {
      "get": {
        "tags": [
          "Geocoding"
        ],
        "summary": "Coordinate → coarse label + structured address (cached; coordinates quantized to a ~100 m grid).",
        "operationId": "ReverseGeocode",
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?(?:[eE][+-]?\\d+)?$",
              "type": [
                "number",
                "string"
              ],
              "format": "double"
