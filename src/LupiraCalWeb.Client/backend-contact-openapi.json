  "components": {
    "schemas": {
      "Access": {
        "enum": [
          "Owner",
          "ReadWrite",
          "Read"
        ]
      },
      "AddContactRelationRequest": {
        "required": [
          "toContactId",
          "kind"
        ],
        "type": "object",
        "properties": {
          "toContactId": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/ContactRelationKind"
          },
          "label": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AddressBookDto": {
        "required": [
          "id",
          "slug",
          "access"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "slug": {
            "type": "string"
          },
          "displayName": {
            "type": [
              "null",
              "string"
            ]
          },
          "access": {
            "$ref": "#/components/schemas/Access"
          }
        }
      },
      "CompletenessGap": {
        "required": [
          "field",
          "weight",
          "severity"
        ],
        "type": "object",
